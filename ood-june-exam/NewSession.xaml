<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ood_june_exam"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="ood_june_exam.NewSession"
        mc:Ignorable="d"
        Title="NewSession" Height="450" Width="452">
    <Grid>
        <TextBlock HorizontalAlignment="Center" Margin="0,44,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="248" FontWeight="Bold" FontSize="18"><Run Language="fr-fr" Text="Add New Training Session"/></TextBlock>
        <TextBox x:Name="TxtStartTime" HorizontalAlignment="Left" Margin="140,144,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="230" TextChanged="TextBox_TextChanged"/>
        <TextBox x:Name="TxtSessionType" HorizontalAlignment="Left" Margin="140,199,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="230"/>
        <DatePicker x:Name="TxtDate" HorizontalAlignment="Left" Margin="140,99,0,0" VerticalAlignment="Top" Width="230"/>
        <TextBox x:Name="TxtCoachNote" HorizontalAlignment="Left" Margin="140,294,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="230" Height="69"/>
        <Button Content="CANCEL" HorizontalAlignment="Left" Margin="49,377,0,0" VerticalAlignment="Top" Width="67"/>
        <Button Content="SAVE" HorizontalAlignment="Left" Margin="140,377,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.48,0.503" Click="Button_Click" Width="230"/>
        <TextBlock HorizontalAlignment="Left" Margin="49,104,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="106" FontSize="11"><Run Language="fr-fr" Text="Date"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="49,147,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="106" FontSize="11"><Run Language="fr-fr" Text="Start Time"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="49,202,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="106" FontSize="11"><Run Language="fr-fr" Text="Session Type"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="49,248,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="106" FontSize="11"><Run Text="Duration "/><Run Language="fr-fr" Text="(m"/><Run Text="in"/><Run Language="fr-fr" Text="s)"/></TextBlock>
        <TextBlock HorizontalAlignment="Left" Margin="49,294,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="106" FontSize="11"><Run Language="fr-fr" Text="Coach Notes"/></TextBlock>

        <materialDesign:NumericUpDown x:Name="TxtDuration" HorizontalAlignment="Left" Margin="140,239,0,0" VerticalAlignment="Top" Height="40" Width="230" RenderTransformOrigin="0.539,0.476"/>

    </Grid>
</Window>
